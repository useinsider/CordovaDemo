{
  "name": "cordova-plugin-insider",
  "version": "4.0.0",
  "description": "A plugin that you can use Insider SDK with Cordova and Ionic",
  "cordova_name": "Insider Cordova Plugin",
  "cordova": {
    "id": "cordova-plugin-insider",
    "platforms": [
      "android",
      "ios"
    ]
  },
  "scripts": {
    "build": "babel js --out-dir www --copy-files --ignore '**/__tests__/**'",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "keywords": [
    "cordova-plugin-insider",
    "cordova-insider",
    "ionic-insider"
  ],
  "main": "www/InsiderPlugin.js",
  "typings": "types/InsiderPlugin.d.ts",
  "author": "useinsider",
  "license": "ISC",
  "devDependencies": {
    "@babel/cli": "^7.27.2",
    "@babel/core": "^7.27.4",
    "@babel/preset-env": "^7.27.2",
    "jest": "^29.7.0"
  },
  "dependencies": {
    "babel": "^6.23.0"
  }
}
